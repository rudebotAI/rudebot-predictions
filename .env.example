# ============================================================
# PredictionBot Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Mode: paper or live
BOT_MODE=paper

# --- Kalshi ---
KALSHI_EMAIL=
KALSHI_API_KEY=

# --- Polymarket ---
POLYMARKET_PRIVATE_KEY=

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Research APIs ---
BRAVE_API_KEY=
X_BEARER_TOKEN=

# --- Coinbase (optional) ---
COINBASE_API_KEY=
COINBASE_API_SECRET=

# --- Risk Limits (override config.yaml) ---
# MAX_DAILY_LOSS_USD=100
# MAX_POSITION_USD=50
# MAX_OPEN_POSITIONS=5
# KELLY_FRACTION=0.25
